# Database (SQLite via Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Rendered image storage directory
STORAGE_ROOT="./storage"

# Google Sheets service account (OPTIONAL — only for importing scripts from
# a Google Sheet; the TSV paste path needs no setup at all).
# Flatten the service-account JSON to a single line. See README → Environment.
GOOGLE_SERVICE_ACCOUNT_JSON=""
