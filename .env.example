# Database (SQLite qua Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Google Gemini — bắt buộc cho generate ảnh thật + AI edit kịch bản
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_IMAGE_MODEL="gemini-3.1-flash-image"
GEMINI_TEXT_MODEL="gemini-flash-latest"

# "gemini" | "mock" — bỏ trống = tự chọn (gemini nếu có key, ngược lại mock)
IMAGE_PROVIDER=""

# Google Sheets service account (dán toàn bộ JSON credentials thành 1 dòng).
# Xem README mục "Google Sheets" để biết cách tạo. Bỏ trống nếu chỉ dùng TSV.
GOOGLE_SERVICE_ACCOUNT_JSON=""

# Giới hạn & vận hành
DAILY_GEN_LIMIT="40"
STORAGE_ROOT="./storage"
JOB_CONCURRENCY="1"
