generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id            String   @id @default(cuid())
  name          String
  characterDesc String?
  aspectRatio   String   @default("16:9") // "16:9" | "9:16" | "1:1" | "4:5"
  resolution    String   @default("1K") // "1K" | "2K"
  playbackSpeed Float    @default(1.5) // giây/frame cho preview
  sheetUrl      String?
  wmPosition    String   @default("bottom-right") // 4 góc + "center"
  wmScale       Float    @default(12) // % chiều rộng ảnh
  wmOpacity     Float    @default(0.85)

  // ---- Phase 9: video settings ----
  videoTier          String    @default("animatic") // animatic|lite|fast|standard
  clipDurationSec    Int       @default(8) // 4|6|8 (Veo); animatic tự do
  videoResolution    String    @default("720p") // 720p|1080p
  transitionType     String    @default("cut") // cut|crossfade
  transitionSec      Float     @default(0.4)
  captionsBurnIn     Boolean   @default(true)
  colorPolish        Boolean   @default(true)
  bgmEnabled         Boolean   @default(true)
  bgmVolumeDb        Float     @default(-6)
  voiceoverEnabled   Boolean   @default(true)
  nativeAudioEnabled Boolean   @default(true)
  finalVideoPath     String?
  finalVideoStatus   String    @default("none") // none|rendering|done|failed
  finalVideoError    String?
  finalRenderedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  frames    Frame[]
  assets    Asset[]
  clips     Clip[]
}

model Frame {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  index        Int // 1-based → hiển thị F01, F02...
  shotType     String
  description  String
  status       String    @default("draft") // draft|pending|generating|watermarking|done|failed
  imagePath    String? // ảnh đã watermark (hiển thị)
  rawImagePath String? // ảnh gốc chưa watermark
  seed         Int? // provider hiện không hỗ trợ seed — giữ cho tương lai
  errorMsg     String?
  generatedAt  DateTime?

  // ---- Phase 9: voiceover + motion ----
  voiceoverText String? // lời thuyết minh (TTS đọc)
  voPath        String? // file wav TTS đã sinh (cache theo hash text)
  interpToNext  Boolean @default(false) // clip nội suy frame này → frame kế

  clip Clip?

  @@unique([projectId, index])
}

// Phase 9: 1 clip video / frame
model Clip {
  id             String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  frameId       String    @unique
  frame         Frame     @relation(fields: [frameId], references: [id], onDelete: Cascade)
  tier          String // animatic|lite|fast|standard
  mode          String    @default("per-frame") // per-frame|interp
  status        String    @default("pending") // pending|generating|downloading|done|failed
  clipPath      String?
  durationSec   Float     @default(8)
  hasNativeAudio Boolean  @default(false)
  operationName String? // Veo long-running operation (debug)
  errorMsg      String?
  generatedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@unique([projectId, frameId])
}

model Asset {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      String // "mascot_ref" (≤3) | "style_ref" (≤3) | "watermark" (=1)
  filePath  String
  mimeType  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model GenerationLog {
  id        String   @id @default(cuid())
  projectId String
  frameId   String
  provider  String
  kind      String   @default("image") // image|video|tts
  seconds   Int      @default(0) // số giây video (0 với image/tts)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
